# ─────────────────────────────────────────────────────────────
#  .env.example — PRODUCTION TEMPLATE
#  Copy this to .env on your server and fill in all values.
#  Generate a new SECRET_KEY with:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ─────────────────────────────────────────────────────────────

DJANGO_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=littlesteps_db
DB_USER=db_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# Gmail SMTP (use an App Password, not your real Gmail password)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=schoolemail@gmail.com
EMAIL_HOST_PASSWORD=REPLACE_WITH_APP_PASSWORD

DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SCHOOL_NOTIFICATION_EMAIL=principal@yourdomain.com
